<form title="fabric" width="600" height="500">
    <layout direction="v" gutter="10" style="flex: 1; padding: 10px;">
        <fabric style="flex: 1; border: solid 1px var(--g-border-color);" :disabled="disabled" @init="onInit"></fabric>
        <layout gutter="10" align-v="center">
            <button @click="disabled = !disabled">{{disabled ? '' : '!'}}disabled</button>
            <label>You can drag or resize the shapes.</label>
        </layout>
    </layout>
</form>
